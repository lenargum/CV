---
// English focused profiles at /react/, /vue/, /fullstack/.
import Layout from "../layouts/Layout.astro";
import CVContent from "../components/CVContent.tsx";
import { composeCv } from "../lib/composeCv";
import { PROFILES } from "../lib/types";
import type { ProfileType } from "../lib/types";

export function getStaticPaths() {
  // 'all' is served at site root via index.astro, so this dynamic
  // route only generates the focused profiles.
  return PROFILES.filter(p => p !== 'all').map(profile => ({
    params: { profile },
    props: { profile },
  }));
}

interface Props {
  profile: ProfileType;
}

const { profile } = Astro.props;
const lang = 'en' as const;

const cv = composeCv(profile, lang);
const allTags = cv.tags;
const pageTitle = `${cv.personalInfo.name} - ${cv.personalInfo.title}`;
---

<Layout
  title={pageTitle}
  description={cv.personalInfo.description}
  lang={lang}
  profile={profile}
>
  <CVContent
    client:visible
    personalInfo={cv.personalInfo}
    summary={cv.summary}
    experiences={cv.experiences}
    education={cv.education}
    awards={cv.awards}
    teaching={cv.teaching}
    allTags={allTags}
    initialLang={lang}
    profile={profile}
  />
</Layout>
