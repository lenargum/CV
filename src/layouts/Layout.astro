---
import "../styles/global.css";
import NoiseBackground from "../components/NoiseBackground";
import { LangSwitcher, ProfileSwitcher } from "../components/QuickLanguageSwitcher";
import PDFModal from "../components/PDFModal";
import { withBasePath } from "../lib/utils";
import type { LangType, ProfileType } from "../lib/types";

const localeMap: Record<LangType, string> = {
  en: "en_US",
  ru: "ru_RU",
};

interface Props {
  title: string;
  description: string;
  lang?: LangType;
  profile?: ProfileType;
}

const { title, description, lang = "en", profile = "all" } = Astro.props as Props;
// URL scheme: EN at root (/, /react/, ...); RU under /ru/ (/ru/, /ru/react/, ...).
const langSegment = lang === 'en' ? '' : 'ru/';
const profileSegment = profile === 'all' ? '' : `${profile}/`;
const canonicalUrl = withBasePath(`${langSegment}${profileSegment}`);
const ogLocale = localeMap[lang];

// === Mobile menu data, prepared in frontmatter to keep the template clean.
const profileLabels: Record<ProfileType, { en: string; ru: string }> = {
  all: { en: 'All', ru: 'Всё' },
  react: { en: 'React', ru: 'React' },
  vue: { en: 'Vue', ru: 'Vue' },
  fullstack: { en: 'Fullstack', ru: 'Fullstack' },
};
const profileItems = (['all', 'react', 'vue', 'fullstack'] as ProfileType[]).map(p => ({
  p,
  href: withBasePath(`${langSegment}${p === 'all' ? '' : `${p}/`}`),
  label: profileLabels[p][lang],
}));
const langItems = (['en', 'ru'] as LangType[]).map(l => ({
  l,
  href: withBasePath(`${l === 'en' ? '' : 'ru/'}${profileSegment}`),
  label: l === 'en' ? 'English' : 'Русский',
}));
// Per-(lang,profile) OG card generated by `pnpm og` into public/og/.
// Cache-busted via ?v= so feeds re-fetch when we regenerate.
const ogImageUrl = withBasePath(`og/og-${lang}-${profile}.png?v=5`);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Lenar Gumerov — CV" />
    <meta property="og:locale" content={ogLocale} />

    <!-- OG image — per-(lang,profile) card generated by `pnpm og` -->
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={title} />

    <!-- Square fallback for chat clients that prefer 1:1 (Telegram link previews) -->
    <meta property="og:image" content={withBasePath(`avatar-1024.png?v=2`)} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={withBasePath(`favicon.svg`)} />

    <!-- Robots -->
    <meta name="robots" content="index,follow,max-image-preview:large" />
  </head>
  <body class="flex justify-center bg-secondary" style="min-height: 100dvh">
    <NoiseBackground client:idle />

    {/* Mobile hamburger — anchored to the cv-card top-right (visually inside
        the card). Toggles a full-screen overlay menu. */}
    <button
      id="cv-burger"
      class="cv-burger"
      aria-label={lang === 'ru' ? 'Меню' : 'Menu'}
      aria-expanded="false"
      aria-controls="cv-menu-overlay"
      type="button"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7"  x2="20" y2="7"  />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>

    {/* Lava lamp toggle — standalone top-LEFT (asymmetric to chrome cluster),
        kept OUTSIDE cv-chrome so the chrome's `is-hidden` opacity/blur in
        lava mode doesn't take the user's only escape hatch with it. */}
    <button
      id="lava-toggle"
      class="cv-lava cv-lava--off cv-tip cv-tip--left"
      data-tip={lang === 'ru' ? 'Режим лава-лампы: ВЫКЛ' : 'Lava lamp mode: OFF'}
      aria-label={lang === 'ru' ? 'Режим лава-лампы' : 'Lava lamp mode'}
      aria-pressed="false"
      type="button"
    >
      <img src={withBasePath("lava-lamp.png")} alt="" />
    </button>

    {/* Floating chrome — desktop only (PDF + lang) at the top-right
        corner. Mobile uses the hamburger + overlay below. */}
    <div id="cv-chrome" class="cv-chrome">
      <div class="cv-chrome__row">
        <button
          id="cv-pdf-btn"
          type="button"
          class="cv-pdf-iconbtn cv-tip"
          data-tip="PDF"
          aria-label="PDF"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="12" y1="12" x2="12" y2="18" />
            <polyline points="9 15 12 18 15 15" />
          </svg>
        </button>
        <LangSwitcher profile={profile} currentLang={lang} client:load />
      </div>
    </div>

    {/* === Mobile full-screen menu overlay === */}
    <div id="cv-menu-overlay" class="cv-menu-overlay" aria-hidden="true">
      <button
        type="button"
        class="cv-menu-overlay__backdrop"
        aria-label={lang === 'ru' ? 'Закрыть меню' : 'Close menu'}
      ></button>
      <nav class="cv-menu-overlay__panel cv-card" aria-label={lang === 'ru' ? 'Меню' : 'Menu'}>
        <div class="cv-menu-overlay__bar">
          <h2 class="cv-menu-overlay__title">{lang === 'ru' ? 'Меню' : 'Menu'}</h2>
          <button
            id="cv-menu-close"
            type="button"
            class="cv-menu-overlay__close"
            aria-label={lang === 'ru' ? 'Закрыть' : 'Close'}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="6"  y1="6"  x2="18" y2="18" />
              <line x1="18" y1="6"  x2="6"  y2="18" />
            </svg>
          </button>
        </div>

        {/* Profile + language reuse the SAME pill components used elsewhere on
            the site — the active state, colors, and hover all come for free
            from the design system. */}
        <div class="cv-menu-overlay__group">
          <span class="cv-menu-overlay__label">{lang === 'ru' ? 'Профиль' : 'Profile'}</span>
          <ProfileSwitcher activeProfile={profile} currentLang={lang} client:load />
        </div>

        <div class="cv-menu-overlay__group">
          <span class="cv-menu-overlay__label">{lang === 'ru' ? 'Язык' : 'Language'}</span>
          <LangSwitcher profile={profile} currentLang={lang} client:load />
        </div>

        <div class="cv-menu-overlay__divider"></div>

        <div class="cv-menu-overlay__group">
          <span class="cv-menu-overlay__label">{lang === 'ru' ? 'Действия' : 'Actions'}</span>
          {/* Primary CTA — download the PDF directly. */}
          <button id="cv-menu-pdf" type="button" class="cv-menu-overlay__cta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="12" y1="12" x2="12" y2="18" />
              <polyline points="9 15 12 18 15 15" />
            </svg>
            <span>{lang === 'ru' ? 'Скачать PDF' : 'Download PDF'}</span>
          </button>

          {/* Toggle row — label + visual switch indicating ON/OFF state. */}
          <button
            id="cv-menu-lava"
            type="button"
            class="cv-menu-overlay__toggle"
            role="switch"
            aria-checked="false"
          >
            <span class="cv-menu-overlay__toggle-label">
              <img src={withBasePath("lava-lamp.png")} alt="" class="cv-menu-overlay__toggle-icon" />
              <span>{lang === 'ru' ? 'Лава-лампа' : 'Lava lamp'}</span>
            </span>
            <span class="cv-menu-overlay__switch" aria-hidden="true">
              <span class="cv-menu-overlay__switch-thumb"></span>
            </span>
          </button>
        </div>
      </nav>
    </div>

    <main class="w-full max-w-[920px] z-10">
      <slot />
    </main>

    <PDFModal lang={lang} profile={profile} base={import.meta.env.BASE_URL} client:load />
  </body>
</html>

<style>
  html, body {
    height: 100dvh;
    /* Block bounce/rubber-band overscroll AND horizontal swipe-back gestures
       (iOS/Android browsers). touch-action: pan-y means only vertical scroll
       is recognised — left/right swipes don't trigger history navigation. */
    overscroll-behavior: none;
    touch-action: pan-y;
  }
  html {
    overflow-y: scroll;
    /* Hide scrollbar visually on the main site (keeps scroll behavior intact).
       PDF preview iframe is a separate document and not affected. */
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/legacy Edge */
  }
  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
  }
  /* Lava mode = full-screen screensaver. Disable ALL touch gestures so
     stray swipes don't navigate back / trigger pull-to-refresh. */
  body.lava-mode {
    touch-action: none;
    overflow: hidden;
  }

  @media print {
    body {
      background-color: white !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    main {
      max-width: 100% !important;
      box-shadow: none !important;
    }
  }
</style>

<script>
  // PDF / Print button — fires custom event picked up by the React PDFModal
  // island below. Modal opens, loads /pdf/{lang}/{profile}/ in iframe.
  const pdfBtn = document.getElementById("cv-pdf-btn");
  pdfBtn?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("cv-pdf-open"));
  });

  // === Mobile menu overlay ===
  const burger = document.getElementById("cv-burger");
  const overlay = document.getElementById("cv-menu-overlay");
  const overlayClose = document.getElementById("cv-menu-close");
  const overlayBackdrop = overlay?.querySelector(".cv-menu-overlay__backdrop");
  const setMenuOpen = (open) => {
    document.body.classList.toggle("menu-open", open);
    burger?.setAttribute("aria-expanded", open ? "true" : "false");
    overlay?.setAttribute("aria-hidden", open ? "false" : "true");
  };
  burger?.addEventListener("click", () => {
    // If we're in lava mode, opening the menu also exits lava — the menu
    // shouldn't appear over the screensaver, that's confusing.
    if (document.body.classList.contains("lava-mode")) toggle();
    setMenuOpen(!document.body.classList.contains("menu-open"));
  });
  overlayClose?.addEventListener("click", () => setMenuOpen(false));
  overlayBackdrop?.addEventListener("click", () => setMenuOpen(false));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && document.body.classList.contains("menu-open")) {
      setMenuOpen(false);
    }
  });

  // Mobile menu — PDF item fires the same custom event as the floating PDF
  // button and then closes the overlay.
  document.getElementById("cv-menu-pdf")?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("cv-pdf-open"));
    setMenuOpen(false);
  });

  const btn = document.getElementById("lava-toggle");
  const chrome = document.getElementById("cv-chrome");
  const menuLava = document.getElementById("cv-menu-lava");
  const lavaTipRu = { on: "Режим лава-лампы: ВКЛ", off: "Режим лава-лампы: ВЫКЛ" };
  const lavaTipEn = { on: "Lava lamp mode: ON",   off: "Lava lamp mode: OFF" };
  const lavaTip = document.documentElement.lang === "ru" ? lavaTipRu : lavaTipEn;
  const updateButton = () => {
    const on = document.body.classList.contains("lava-mode");
    btn?.classList.toggle("cv-lava--on", on);
    btn?.classList.toggle("cv-lava--off", !on);
    btn?.setAttribute("aria-pressed", on ? "true" : "false");
    btn?.setAttribute("data-tip", on ? lavaTip.on : lavaTip.off);
    // Floating chrome hides in lava mode so the noise field is unobstructed
    chrome?.classList.toggle("is-hidden", on);
    // Mobile menu lava — flip aria-checked so the iOS-style switch animates
    menuLava?.setAttribute("aria-checked", on ? "true" : "false");
  };
  const toggle = () => {
    document.body.classList.toggle("lava-mode");
    const on = document.body.classList.contains("lava-mode");
    window.dispatchEvent(
      new CustomEvent("lava-mode-change", { detail: { on } })
    );
    updateButton();
    if (on) {
      document.documentElement.style.overflow = "hidden";
    } else {
      document.documentElement.style.overflow = "";
    }
  };
  btn?.addEventListener("click", toggle);
  // Mobile menu Lava button — same toggle, then close the overlay so user
  // can immediately see the lava effect.
  menuLava?.addEventListener("click", () => {
    toggle();
    setMenuOpen(false);
  });

  // ensure initial state styles
  updateButton();
</script>
