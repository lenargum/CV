---
import "../styles/global.css";
import NoiseBackground from "../components/NoiseBackground";
import { LangSwitcher } from "../components/QuickLanguageSwitcher";
import PDFModal from "../components/PDFModal";
import { withBasePath } from "../lib/utils";
import type { LangType, ProfileType } from "../lib/types";

const localeMap: Record<LangType, string> = {
  en: "en_US",
  ru: "ru_RU",
};

interface Props {
  title: string;
  description: string;
  lang?: LangType;
  profile?: ProfileType;
}

const { title, description, lang = "en", profile = "all" } = Astro.props as Props;
// URL scheme: EN at root (/, /react/, ...); RU under /ru/ (/ru/, /ru/react/, ...).
const langSegment = lang === 'en' ? '' : 'ru/';
const profileSegment = profile === 'all' ? '' : `${profile}/`;
const canonicalUrl = withBasePath(`${langSegment}${profileSegment}`);
const ogLocale = localeMap[lang];
// Per-(lang,profile) OG card generated by `pnpm og` into public/og/.
// Cache-busted via ?v= so feeds re-fetch when we regenerate.
const ogImageUrl = withBasePath(`og/og-${lang}-${profile}.png?v=5`);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Lenar Gumerov — CV" />
    <meta property="og:locale" content={ogLocale} />

    <!-- OG image — per-(lang,profile) card generated by `pnpm og` -->
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={title} />

    <!-- Square fallback for chat clients that prefer 1:1 (Telegram link previews) -->
    <meta property="og:image" content={withBasePath(`avatar-1024.png?v=2`)} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={withBasePath(`favicon.svg`)} />

    <!-- Robots -->
    <meta name="robots" content="index,follow,max-image-preview:large" />
  </head>
  <body class="flex justify-center bg-secondary" style="min-height: 100dvh">
    <NoiseBackground client:idle />
    <button
      id="lava-toggle"
      class="cv-lava cv-lava--off cv-tip cv-tip--left"
      data-tip={lang === 'ru' ? 'Режим лава-лампы: ВЫКЛ' : 'Lava lamp mode: OFF'}
      aria-label={lang === 'ru' ? 'Режим лава-лампы' : 'Lava lamp mode'}
      aria-pressed="false"
      type="button"
    >
      <img src={withBasePath("lava-lamp.png")} alt="" />
    </button>
    <!-- Floating top-right chrome: PDF + language pill -->
    <div id="cv-chrome" class="cv-chrome">
      <div class="cv-chrome__row">
        <button
          id="cv-pdf-btn"
          type="button"
          class="cv-pdf-iconbtn cv-tip"
          data-tip="PDF"
          aria-label="PDF"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="12" y1="12" x2="12" y2="18" />
            <polyline points="9 15 12 18 15 15" />
          </svg>
        </button>
        <LangSwitcher profile={profile} currentLang={lang} client:load />
      </div>
    </div>

    <main class="w-full max-w-[920px] z-10">
      <slot />
    </main>

    <PDFModal lang={lang} profile={profile} base={import.meta.env.BASE_URL} client:load />
  </body>
</html>

<style>
  html {
    height: 100dvh;
    overflow-y: scroll;
    /* Hide scrollbar visually on the main site (keeps scroll behavior intact).
       PDF preview iframe is a separate document and not affected. */
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/legacy Edge */
  }
  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
  }

  @media print {
    body {
      background-color: white !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    main {
      max-width: 100% !important;
      box-shadow: none !important;
    }
  }
</style>

<script>
  // PDF / Print button — fires custom event picked up by the React PDFModal
  // island below. Modal opens, loads /pdf/{lang}/{profile}/ in iframe.
  const pdfBtn = document.getElementById("cv-pdf-btn");
  pdfBtn?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("cv-pdf-open"));
  });

  const btn = document.getElementById("lava-toggle");
  const chrome = document.getElementById("cv-chrome");
  const lavaTipRu = { on: "Режим лава-лампы: ВКЛ", off: "Режим лава-лампы: ВЫКЛ" };
  const lavaTipEn = { on: "Lava lamp mode: ON",   off: "Lava lamp mode: OFF" };
  const lavaTip = document.documentElement.lang === "ru" ? lavaTipRu : lavaTipEn;
  const updateButton = () => {
    const on = document.body.classList.contains("lava-mode");
    btn?.classList.toggle("cv-lava--on", on);
    btn?.classList.toggle("cv-lava--off", !on);
    btn?.setAttribute("aria-pressed", on ? "true" : "false");
    btn?.setAttribute("data-tip", on ? lavaTip.on : lavaTip.off);
    // Floating chrome hides in lava mode so the noise field is unobstructed
    chrome?.classList.toggle("is-hidden", on);
  };
  const toggle = () => {
    document.body.classList.toggle("lava-mode");
    const on = document.body.classList.contains("lava-mode");
    window.dispatchEvent(
      new CustomEvent("lava-mode-change", { detail: { on } })
    );
    updateButton();
    if (on) {
      document.documentElement.style.overflow = "hidden";
    } else {
      document.documentElement.style.overflow = "";
    }
  };
  btn?.addEventListener("click", toggle);
  // ensure initial state styles
  updateButton();
</script>
